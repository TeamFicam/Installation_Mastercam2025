scncpost_revision     := "27.84" # Internal revision number for use by CNC Software only.  Please do not change this number.
scustpost_revision    := "0"  # Revision number for use by Resellers or customers.
# Post Name           : MPROUTER.pst
# Product             : Router
# Machine Name        : Generic
# Control Name        : Fanuc
# Description         : Generic 4 Axis Router Post
# 4-axis/Axis subs.   : Yes (SKELETON)
# 5-axis              : No
# Subprograms         : Yes
# Block Drill Spprt.  : Yes
# Multi-Head Spprt.   : Yes
# Aggregate Spprt.    : Yes
# Dust Hood Spprt.    : Yes
# Twin Table Spprt.   : Yes (Misc Int. selection)
# Executable          : mp.dll
#
# WARNING: THIS POST IS GENERIC AND IS INTENDED FOR MODIFICATION TO
# THE MACHINE TOOL REQUIREMENTS AND PERSONAL PREFERENCE.
#
# THIS POST REQUIRES A VALID 3 OR 4 AXIS MACHINE DEFINITION.
# YOU WILL RECEIVE AN ERROR MESSAGE IF MORE THAN ONE ROTARY AXIS IS DETECTED IN
# THE ACTIVE AXIS COMBINATION IF READ_MD IS SET TO YES.
# ONLY C-AXIS (about the Z axis) ROTATION IS SUPPORTED.
#
# Associated File List$
#
# default.mcam-control
# ROUTER DEFAULT.mcam-rmd
# ROUTER DEFAULT MM.mcam-rmd
#
# Associated File List$
#
# --------------------------------------------------------------------------
# Revision log:
# --------------------------------------------------------------------------
