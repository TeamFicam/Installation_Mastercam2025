%_N_1000_MPF
;$PATH=/_N_WKS_DIR/_N_Programme_Mastercam_WPD
; --------- CHANNEL: 1 --------------
;MACHINE      : CTX_GAMMA_2000 
;WORKPIECE    : Programme_Mastercam
;DRAWING      : 
;MATERIAL     : 
;MASTERCAMFILE: C:\Users\vfoll\Desktop\2024s\biopack test.emcam
;PROGRAMMER   : 
;DATE         : 01/25/2024  TIME: 17:57
; -----------------------------------
;************************************
; SIEMENS 840D -- CTX GAMMA 2000 ---- 
; MACHINE AS SINGLE STREAM STYLE
; TEMPLATE METRIC, CHUCKING PART, LOAD AND UNLOAD BY HAND
; OPERATIONS ONLY ON MAIN SPINDLE (SP4)
;************************************ 
 EXTERN DUMMY (INT)
 N10 L1000             ;LOADING VARIABLES
NN8010:
 N60 L1001             ;START-UP
 N65 STOPRE
 N70 SETMS(3)
 N71 G26 S3=2500       ;RPM-LIMIT FOR G95
 N72 LIMS=2500         ;RPM-LIMIT FOR G95/G96
 N73 STOPRE
 N75 SETMS(4)
 N76 G26 S4=2500       ;RPM-LIMIT FOR G95
 N77 LIMS=2500         ;RPM-LIMIT FOR G95/G96
 N80 L711(1)           ;TOOL CHANGE POSITION
NN8015:
;******************************
NN8020:
 N150 M1 M99           ;OPTIONAL STOP
 N155 CHECK_MAG        ;CHECK FOR DISENGAGED TOOLS
NN8025:
; ******************************************* 
; **** PART SPECIFIC PROGRAMMING ************ 
; *BEGIN* *********************************** 
; *-----*
;4  |  FRAISE 4  | DIA. -  4
NN8101:
STOPRE
IF RG704 <> 1 GOTOF NN9801    ; RG -- variable, g-- global to all channels
L1101 ; --  SP4
STOPRE
RG704 = 2
GOTOF NN8080 ; goto and look forward
NN9801: DUMMY(1101)
; +-----+
; *END*   *********************************** 
; **** PART SPECIFIC PROGRAMMING ************ 
; ******************************************* 
NN8080:
/N800 SETPIECE(1,1)
NN8090:
NN8100:
 N1000 L1045            ;UNLOAD AND LOAD OF SP4 BY HAND
NN8190:
 N1900 STOPRE
 N1910 IF RG704<>0 GOTOB NN8020 ;MAINSPINDLE
 N1930 GOTOF NN8300
NN8200:
NN8300:
 N3000                 ;SHIFT END
NN9999: M30
____
%_N_L1001_SPF
;$PATH=/_N_WKS_DIR/_N_Programme_Mastercam_WPD
;OPERATION   :START PROGRAM CHANNEL 1 
 N10 R690=1480 R691=650 ;COORDINATES TOOL CHANGE POSITION
 N15 IF CHAN_NO <> 1 GOTOF ERROR_CHAN_NO
 N20 DIAMON
 N25 TRANS_OFF    ;TRANSFORMATIONS OFF
 N30 CLAMP_B1     ;CLAMP/UNCLAMP B-AXIS IN THE BACKGROUND
 N35 L731         ;MOVING TO FIXED STOP OFF
 N40 L727         ;SPINDLESYNCHRONIOUS RUN OFF
 N45 L702         ;C1-AXIS OFF
 N50 L706         ;C3-AXIS OFF
 N55 M313         ;S3-AXIS BRAKE OFF
 N60 L708         ;C4-AXIS OFF
 N65 M413         ;S4-AXIS BRAKE OFF
 N70 L717         ;ACTIVATE RAPID REDUCTION
 N75 G54          ;ZERO POINT OFFSET
 N80 G18 G40 G90  ;TURNING PLANE, CUTTER COMP OFF, ABSOLUTE COORDINATES
 N85 G26 S4=5000  ;MAX. RPM G94/G95 SP4
 N90 G26 S3=5000  ;MAX. RPM G94/G95 SP3
 N95 G26 S1=12000 ;MAX. RPM SP1
 N100 M841        ;CLOSE TOOL HATCH
 N105 STOPRE
 N110 SETMS(4)
 N115 LIMS=4000   ;MAX. RPM G96 SP4
 N120 STOPRE
 N125 SETMS(3)
 N130 LIMS=4000   ;MAX. RPM G96 SP3
 N135 ROT         ;ROTATION OFF
 N140 TRANS       ;SHIFTING OFF
 N145 MIRROR      ;MIRROR OFF
 N150 SCALE       ;SCALE OFF
 N155 SOFT FFWOF  ;LOOK AHEAD OFF
 N160 G0 G153 X=R690 Y0 D0
 N170 L712(1)     ;TOOL CHANGE POSITION
 N175 FGROUP()    ;INTERPOLATION COUPLING OFF
 N180 TOWSTD      ;WEAR IN TOOL LOCATOR ORIENTATION
 ;SET G54 ZERO POINT
 $P_UIFR[1,Z1,TR]=RG714 ;Z1
 $P_UIFR[1,Z3,TR]=RG714 ;Z3
 ;SET G55 ZERO POINT
 $P_UIFR[2,Z1,TR]=RG715 ;Z1
 $P_UIFR[2,Z3,TR]=RG715 ;Z3
 ;SET G56 ZERO POINT
 $P_UIFR[3,Z1,TR]=0 ;Z1
 $P_UIFR[3,Z3,TR]=0 ;Z3
NN9999: M17
 
 ERROR_CHAN_NO:
  MSG("$67008") ;("Wrong channel")
  M0
  GOTOB ERROR_CHAN_NO
 M17
____
%_N_L1045_SPF
;$PATH=/_N_WKS_DIR/_N_Programme_Mastercam_WPD
N0 ;OPERATION   :UNLOAD AND LOAD CHANNEL 1 MANUALLY
N1 ;NOTES :
N2 G18 M814
N3 DIAMON
N4 G54
N5 G59 X0 Y0 Z=RG720
N6 L711(1)
N7 G0 B1=0
N8 IF RG704==0
N9 M433         ;OPEN CHUCK
N10 ELSE
N11 M437         ;CLOSE CHUCK
N12 ENDIF
N13 L707(0)       ;C4-AXIS ON
N14 G0 C4=0       ;JAWS IN SUPPORTING POSITION
N15 M412          ;C4-AXIS BRAKE ON
N16 STOPRE
N17 RG704=1      ;MAINSPINDLE WITH BLANK
N18 MSG ("CHARGER UNE NOUVELLE PIECE")
N19 M67          ;OPEN MACHINE DOOR
N20 M0
N21 IF $AC_REQUIRED_PARTS <> -1 GOTOF NN24 ; SI PAS DE COMPTEUR PIECE
N22 R604 = 1 ;PIECE FINI
N23 RG704 = 0	;PLUS DE BRUT DANS LA BROCHE GAUCHE
N24 GOTOF NN30
NN24: 
N25 R605 = $AC_ACTUAL_PARTS ; R605 = NOMBRE DE PIECE REQUISE
N26 R605 = R605 + 1 ;INCREMENT POUR R605
N27 M18		;INCREMENT COMPTEUR DE PIECE MACHINE
N28 IF $AC_REQUIRED_PARTS <> R605 GOTOF NN30 ; SI NOMBRE PIECE FINI
N29 RG704 = 0 ; PLUS DE BRUT DANS LA BROCHE GAUCHE
NN30: STOPRE
N31 MSG ()
N32 G4 F0
N33 STOPRE
/N34 M437         ;CLOSE CHUCK
N35 M413         ;C4-AXIS BRAKE OFF
N36 L711(1)
N37 L708         ;C4-AXIS OFF
N38 NN9999: M17
N39 ____

____
%_N_L1000_SPF
;$PATH=/_N_WKS_DIR/_N_Programme_Mastercam_WPD
;INITIALIZE VARIABLES
;****************************************
 RG779=100    ;RAPID REDUCTION (INPUT 1-100)
;****************************************
 RG720=49     ;WORKPIECE ZERO POINT SP4
 RG721=0+88+50;LENGTH OF CHUCK+JAWS SP3
 RG722=0      ;SHORT ZERO POINT SP4
 RG724=90.5   ;CLAMPING DEPTH SP3
 RG711=0+58 ;LENGTH OF CHUCK+JAWS SP4
 RG712=0.     ;CUT-OFF WIDTH + ALLOWANCE
 RG713=1200  ;TRAVEL RANGE Z3-AXIS
 RG714=RG711  ;ZERO POINT G54 SP4
 RG715=RG713-RG721 ;ZERO POINT G55 SP3
 RG725=41.5   ;LENGTH OF FINISHED PART
 RG727=0      ;ANGULAR OFFSET SP4
 RG728=0      ;ANGULAR OFFSET SP3
 RG729=0      ;ANGULAR OFFSET BETWEEN SP3 AND SP4
 RG734=1      ;OVERTRAVEL FOR MOVING TO FIXED STOP WITH Z3
 RG735=0.5    ;L. TOLERANCE WINDOW FOR MOVING TO FIXED STOP WITH Z3-AXIS
 RG736=0.5    ;R. TOLERANCE WINDOW FOR MOVING TO FIXED STOP WITH Z3-AXIS
 RG737=0.01   ;PULL BACK AFTER HITTING FIXED STOP WITH Z3-AXIS
 RG738=110   ;BLANK DIAMETER
 R600 = 1     ;Nombres de pieces en repettions
 R601 = 0      ; Utiliser l'ejection de pi?ce oui = 1 non = 0
 R602 = RG721 + 475    ;DISTANCE D'ACCOSTAGE RECUPERATEUR DE PIECE
 R699 = 0    ; REMISE A ZERO DE COMPTEUR DE PIECE
 R603 = 0    ; REMISE A ZERO DU TYPE USINAGE (Gauche a droite ou Multibroche)
;****************************************
 RG723 =RG724-RG725 ;WORKPIECE ZERO POINT SP3
 RG726 =RG720+RG721 ;ZERO POINT Z3 FOR PART TRANSFER

 IF $P_SIM 
 RG704=0  ; STOCK IN MAINSPINDLE
 RG703=0  ; STOCK IN SUBSPINDLE
 RG705=0  ; LOAD/ RELOAD AUTOMATIC
 ENDIF 
NN9999: M17
____
%_N_SHIFT_SPF
;$PATH=/_N_WKS_DIR/_N_Programme_Mastercam_WPD
PROC SHIFT (STRING[20] VARI)

GOTOF "SHIFT_"<<VARI

SHIFT_OFF:
 TRANS
 ROT
 MIRROR
 SCALE
 GOTOF NN9999

SHIFT_SP3:    ; AT SPINDLE 3
 TRANS
 ROT
 MIRROR
 SCALE
G55
G59 X0 Y0 Z=RG723 C3=RG728
 GOTOF NN9999

SHIFT_SP4:    ; AT SPINDLE 4
 TRANS
 ROT
 MIRROR
 SCALE
G54
G59 X0 Y0 Z=RG720 C4=RG727
 GOTOF NN9999

NN9999: M17
____
