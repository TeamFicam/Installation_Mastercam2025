%_N_DUMMY_SPF
;$PATH=/_N_WKS_DIR/_N_SAMPLE_CODE_WPD
PROC DUMMY (INT VARI)
GOTOF "DUMMY_"<<VARI

DUMMY_1101:
GOTOF NN9999

NN9999: M17

;ENDSTREAM

